# Bureau engine configuration — copy to `.env` and fill in. The engine auto-loads
# `.env` from its working directory at startup.

# ── Projects (multi-repo): a JSON array of the repos Bureau works on ──────────
BUREAU_PROJECTS=[{"owner":"you","name":"your-repo","url":"https://github.com/you/your-repo.git","baseBranch":"main"}]
# Root under which each project clones to <root>/<id>/repo and worktrees to <root>/<id>/worktrees.
BUREAU_REPOS_ROOT=./.bureau/repos

# ── GitHub ───────────────────────────────────────────────────────────────────
# Path to the gh CLI (must be authenticated — run `gh auth setup-git` once).
BUREAU_GH_PATH=gh
# Identity used for Bureau's commits.
BUREAU_AUTHOR_NAME=Bureau
BUREAU_AUTHOR_EMAIL=you@example.com

# ── Provider ─────────────────────────────────────────────────────────────────
# Set an API key to use the Anthropic API directly; otherwise the engine delegates
# to the local `claude` CLI (which must be on PATH).
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ─────────────────────────────────────────────────────────────────
PORT=4319
BUREAU_DB=./bureau.db
# BUREAU_GIT_PATH=git

# ── Legacy single-repo (used only when BUREAU_PROJECTS is unset) ──────────────
# BUREAU_REPO_OWNER=you
# BUREAU_REPO_NAME=your-repo
# BUREAU_REPO_URL=https://github.com/you/your-repo.git
# BUREAU_CANONICAL=./.bureau/repo
# BUREAU_WORKTREES=./.bureau/worktrees
# BUREAU_BASE_BRANCH=main
