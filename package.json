{
  "name": "bureau",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build --noEmit",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs packages apps",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "quality": "pnpm build && pnpm lint:boundaries && pnpm test",
    "dev": "node scripts/dev.mjs",
    "clean": "tsc --build --clean"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "dependency-cruiser": "^17.4.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
